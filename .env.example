# LLM for the external Analyst (reads real pages → cited answer) AND the sealed
# Meridian Copilot in apps/internal (decides when to call its altai_research tool).
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o-mini
# Optional: point at an on-prem/OpenAI-compatible endpoint. In Docker the sealed
# internal-app uses this to reach the gateway's LLM proxy, so the API key never
# enters the sealed container (see docker-compose.yml).
OPENAI_BASE_URL=
# Breach APIs (optional)
HIBP_API_KEY=
INTELX_API_KEY=
# Tor SOCKS5 proxy (defaults: host "tor" under Docker, "127.0.0.1" locally)
TOR_SOCKS_HOST=tor
TOR_SOCKS_PORT=9050
# Research MCP adapter port
MCP_PORT=3200
